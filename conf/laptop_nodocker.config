// Laptop profile WITHOUT Docker. Same executor and resources as `laptop`,
// but uses the host's Python 3 directly. Slower than the containerized run
// is not the point: this profile exists so the pipeline can still be
// exercised when the Docker daemon is unavailable (CI environment with
// no Docker, locked-down workstation, etc.).
//
// Usage: nextflow run main.nf -profile laptop_nodocker

process {
    executor = 'local'
    cpus     = 2
    memory   = '4 GB'
    container = ''  // disable container directive inherited from base.config
}

docker {
    enabled = false
}
