// Base process settings shared across profiles

process {
    cpus           = 1
    memory         = '2 GB'
    time           = '1 h'
    errorStrategy  = 'retry'
    maxRetries     = 2

    // Default container: stdlib-only Python is sufficient for v0.10. Phase-
    // specific images (VEP for phase 1, Boltz/Chai for phase 2, etc.) will
    // override via `withName:PHASE1_ANNOTATE { container = ... }` when those
    // phases gain real bioinformatics tooling.
    container = 'rms-isp/base:0.10.0'

    withLabel:cpu_small  { cpus = 1; memory = '2 GB'  }
    withLabel:cpu_medium { cpus = 4; memory = '8 GB'  }
    withLabel:cpu_large  { cpus = 8; memory = '32 GB' }
    withLabel:gpu        { cpus = 4; memory = '32 GB'; accelerator = [request: 1, type: 'a100'] }
}

executor {
    submitRateLimit = '10 sec'
}
