// Base process settings shared across profiles

process {
    cpus           = 1
    memory         = '2 GB'
    time           = '1 h'
    errorStrategy  = 'retry'
    maxRetries     = 2

    withLabel:cpu_small  { cpus = 1; memory = '2 GB'  }
    withLabel:cpu_medium { cpus = 4; memory = '8 GB'  }
    withLabel:cpu_large  { cpus = 8; memory = '32 GB' }
    withLabel:gpu        { cpus = 4; memory = '32 GB'; accelerator = [request: 1, type: 'a100'] }
}

executor {
    submitRateLimit = '10 sec'
}
