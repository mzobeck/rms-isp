// Laptop / local CPU profile
// Docker is enabled by default (uses python:3.11-slim per conf/base.config).
// To run without Docker (slower but no daemon needed), pass `-profile laptop_nodocker`.

process {
    executor = 'local'
    cpus     = 2
    memory   = '4 GB'
}

docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}
