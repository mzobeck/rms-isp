// Default configuration for RMS-ISP
// Profile-specific configs live in conf/

manifest {
    name            = 'rms-isp'
    author          = 'Mark Zobeck'
    description     = 'Rhabdomyosarcoma In Silico Pipeline: variant -> therapeutic hypothesis'
    version         = '0.5.0'
    nextflowVersion = '>=23.10.0'
    homePage        = 'https://github.com/mzobeck/rms-isp'
}

params {
    input            = "${projectDir}/tests/data/toy_patient.vcf"
    cna              = "${projectDir}/assets/empty.cna.tsv"                  // optional; defaults to empty
    fusion           = "${projectDir}/assets/empty.fusion.tsv"               // optional; defaults to empty
    outdir           = "${launchDir}/results"
    sample_id        = "TOY_TUMOR"
    subtype          = "FN"                                                  // FP | FN | UNKNOWN | ALL
    targets_yaml     = "${projectDir}/conf/targets.yaml"
    targets_kb       = "${projectDir}/assets/targets_kb.tsv"
    depmap_summary   = "${projectDir}/assets/depmap_rms_summary.tsv"
    drug_map         = "${projectDir}/assets/drug_target_map.tsv"
    drug_map_extra   = "${projectDir}/assets/dgidb_drugs.tsv"                // auto-generated; refresh via bin/fetch_dgidb.py
}

includeConfig 'conf/base.config'

profiles {
    laptop { includeConfig 'conf/laptop.config' }
    slurm  { includeConfig 'conf/slurm.config' }
    aws    { includeConfig 'conf/aws.config'  }
    gpu    { includeConfig 'conf/gpu.config'  }
}

// Provenance: tag every run
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.svg"
    overwrite = true
}
