/corpus/
/data/
*.bam
*.fastq.gz
*.fastq
*.fq
*.fq.gz
*.bcf
*.vcf.gz
*.vcf.gz.tbi

# Allow toy test data
!tests/data/toy_patient.vcf
!tests/data/toy_patient_expected.json

